#!/bin/bash
# Zprávobot Digest - Environment variables
# Zkopíruj jako env.sh a vyplň skutečné hodnoty
# NIKDY nenahrávej env.sh do gitu!

# Mastodon tokeny pro jednotlivé boty
export ZPRAVOBOT_TOKEN="your_zpravobot_access_token"
export SLUNKOBOT_TOKEN="your_slunkobot_access_token"
export HRUBOT_TOKEN="your_hrubot_access_token"

# Anthropic Claude API key
export ANTHROPIC_API_KEY="your_anthropic_api_key"

# Bluesky app password (vygeneruj na bsky.social → Nastavení → App Passwords)
# Potřebné pouze pokud je bluesky.enabled: true v config/global.yml
export ZPRAVOBOT_BLUESKY_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Cesta k CSV souboru s posty (volitelné - jinak se použije data/posts-latest.csv)
# export CSV_PATH="/app/data/posts-latest.csv"

# Timezone
export TZ="Europe/Prague"
